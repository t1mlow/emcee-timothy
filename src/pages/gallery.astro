---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { siteData } from "../data/site";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Emcee Timothy | Gallery"
  description="Photo and video highlights from Emcee Timothy's hosted events."
  pathname="/gallery"
>
  <Header pathname="/gallery" />

  <main class="pb-5">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-stone-900/10 bg-[#fbfaf7]">

      <!-- Background: broken wave lines -->
      <svg
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 h-full w-full"
        viewBox="0 0 1000 280"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <!-- Fades out in the centre where watermark sits -->
          <mask id="wave-mask">
            <linearGradient id="wave-fade" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%"   stop-color="white" stop-opacity="1"/>
              <stop offset="28%"  stop-color="white" stop-opacity="0.15"/>
              <stop offset="50%"  stop-color="white" stop-opacity="0"/>
              <stop offset="72%"  stop-color="white" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="white" stop-opacity="1"/>
            </linearGradient>
            <rect width="1000" height="280" fill="url(#wave-fade)"/>
          </mask>
        </defs>
        <g mask="url(#wave-mask)" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <!-- Line 1: starts left, cuts off mid-right -->
          <path d="M-20,228 C80,198 180,258 300,218 C420,178 478,238 598,208"
            stroke="rgba(28,25,23,0.055)" stroke-width="1"/>
          <!-- Line 2: starts from centre, runs to right edge -->
          <path d="M440,195 C540,162 640,198 760,172 C860,148 940,188 1020,168"
            stroke="rgba(28,25,23,0.045)" stroke-width="0.9"/>
          <!-- Line 3: full span but fades via opacity, gentle wave -->
          <path d="M-20,168 C100,128 220,188 355,152 C488,118 568,172 718,142 C848,114 938,162 1020,138"
            stroke="rgba(28,25,23,0.04)" stroke-width="0.9"/>
          <!-- Line 4: short fragment, left side only -->
          <path d="M-20,138 C88,98 238,156 375,118"
            stroke="rgba(28,25,23,0.035)" stroke-width="0.8"/>
          <!-- Line 5: starts right of centre, runs off right -->
          <path d="M520,110 C648,76 748,118 868,88 C940,68 990,96 1020,82"
            stroke="rgba(28,25,23,0.03)" stroke-width="0.8"/>
          <!-- Line 6: near top, short fragment centre-left -->
          <path d="M60,78 C160,44 290,92 430,58 C530,32 610,68 720,48"
            stroke="rgba(28,25,23,0.03)" stroke-width="0.7"/>
          <!-- Line 7: bottom, long but stops before right edge -->
          <path d="M-20,248 C55,228 152,262 262,240 C372,216 438,252 556,230 C674,206 798,244 890,224"
            stroke="rgba(28,25,23,0.04)" stroke-width="0.8"/>
          <!-- Line 8: top, right fragment only -->
          <path d="M680,32 C788,12 878,42 980,22"
            stroke="rgba(28,25,23,0.025)" stroke-width="0.7"/>
        </g>

        <!-- Sparkle accents -->
        <g transform="translate(860, 42)" opacity="0.22">
          <path d="M0,-8 L0.9,0 L0,8 L-0.9,0 Z" fill="rgba(28,25,23,1)"/>
          <path d="M-8,0 L0,0.9 L8,0 L0,-0.9 Z" fill="rgba(28,25,23,1)"/>
        </g>
        <g transform="translate(130, 234)" opacity="0.15">
          <path d="M0,-6 L0.7,0 L0,6 L-0.7,0 Z" fill="rgba(28,25,23,1)"/>
          <path d="M-6,0 L0,0.7 L6,0 L0,-0.7 Z" fill="rgba(28,25,23,1)"/>
        </g>
        <circle cx="480" cy="18" r="1.2" fill="rgba(28,25,23,0.12)"/>
        <circle cx="920" cy="252" r="1" fill="rgba(28,25,23,0.10)"/>
      </svg>

      <!-- Watermark + overlaid description, stacked and centred -->
      <div class="relative flex flex-col items-center justify-center py-10 sm:py-12">
        <!-- Watermark with top+bottom fade -->
        <div
          class="pointer-events-none select-none overflow-hidden"
          aria-hidden="true"
          style="-webkit-mask-image: linear-gradient(to bottom, transparent 0%, white 30%, white 70%, transparent 100%); mask-image: linear-gradient(to bottom, transparent 0%, white 30%, white 70%, transparent 100%);"
        >
          <p
            class="text-center font-['Plus_Jakarta_Sans'] text-[clamp(5rem,18vw,18rem)] font-semibold uppercase leading-none tracking-[-0.06em] text-stone-900/[0.055]"
          >
            Gallery
          </p>
        </div>

        <!-- Description overlaid in the centre of the watermark -->
        <div class="absolute inset-0 flex flex-col items-center justify-center px-5">
          <div class="flex items-center gap-3">
            <span class="block h-px w-8 bg-stone-400/60"></span>
            <span class="text-[0.62rem] font-semibold uppercase tracking-[0.45em] text-stone-500">In the frame</span>
            <span class="block h-px w-8 bg-stone-400/60"></span>
          </div>
          <p class="mt-3 max-w-xs text-center text-sm leading-7 text-stone-500 sm:max-w-sm sm:text-base sm:leading-8">
            Photos and video highlights — community celebrations, corporate
            functions, and live moments.
          </p>
        </div>
      </div>
    </section>

    <!-- Photo gallery -->
    <section class="border-b border-stone-900/10 bg-[#fbfaf7] py-20 sm:py-24">
      <div class="mx-auto max-w-7xl space-y-10 px-5 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Photo gallery"
          title="Live moments, crowd interaction, and after-event snapshots."
          mobileCenter={true}
        />

        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {
            siteData.photos.map((photo) => (
              <article>
                <div class="relative">
                  <div
                    class="pointer-events-none absolute inset-0 translate-x-[6px] translate-y-[6px] border border-stone-900/12"
                    aria-hidden="true"
                  ></div>
                  <div class="group relative overflow-hidden border border-stone-900/12">
                    <span
                      class="pointer-events-none absolute left-3 top-3 z-10 block h-5 w-5 border-l border-t border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    <span
                      class="pointer-events-none absolute bottom-3 right-3 z-10 block h-5 w-5 border-b border-r border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    <img
                      src={photo.image}
                      alt={photo.title}
                      class="h-72 w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03]"
                    />
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Video showcase -->
    <section class="bg-[#f0ebe3] py-20 sm:py-24">
      <div class="mx-auto max-w-7xl space-y-10 px-5 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Video showcase"
          title="Short highlights from hosted events."
          mobileCenter={true}
        />

        <div class="grid gap-8 lg:grid-cols-3">
          {
            siteData.videos.map((video) => (
              <article class="space-y-5 text-center lg:text-left">
                <div class="relative">
                  <div
                    class="pointer-events-none absolute inset-0 translate-x-[6px] translate-y-[6px] border border-stone-900/12"
                    aria-hidden="true"
                  ></div>
                  <div class="group relative overflow-hidden border border-stone-900/12">
                    <span
                      class="pointer-events-none absolute left-3 top-3 z-10 block h-5 w-5 border-l border-t border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    <span
                      class="pointer-events-none absolute bottom-3 right-3 z-10 block h-5 w-5 border-b border-r border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    {video.videoSrc ? (
                      <video
                        src={video.videoSrc}
                        poster={video.poster}
                        controls
                        preload="none"
                        class="h-64 w-full object-cover"
                      />
                    ) : (
                      <img
                        src={video.poster}
                        alt={video.title}
                        class="h-64 w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03]"
                      />
                    )}
                  </div>
                </div>
                <div class="space-y-2 px-1">
                  <div class="flex items-center justify-center gap-3 lg:justify-start">
                    <span class="block h-px w-6 bg-stone-400/50"></span>
                    <p class="text-[0.6rem] font-semibold uppercase tracking-[0.35em] text-stone-500">
                      {video.duration} · Event highlight
                    </p>
                  </div>
                  <h2 class="font-['Plus_Jakarta_Sans'] text-lg font-semibold tracking-[-0.03em] text-stone-900">
                    {video.description}
                  </h2>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
