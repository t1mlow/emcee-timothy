---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { siteData } from "../data/site";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Emcee Timothy | Gallery"
  description="Photo and video highlights from Emcee Timothy's hosted events."
  pathname="/gallery"
>
  <Header pathname="/gallery" />

  <main class="pb-5">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-stone-900/10 bg-[#fbfaf7]">

      <!-- Subtle diagonal ruled lines (different texture from home dot grid) -->
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.035]"
        aria-hidden="true"
        style="background-image: repeating-linear-gradient(135deg, rgba(28,25,23,1) 0px, rgba(28,25,23,1) 1px, transparent 1px, transparent 36px);"
      ></div>

      <!-- Main content -->
      <div class="relative z-10 mx-auto max-w-7xl px-5 pb-0 pt-20 sm:px-6 lg:px-8 lg:pt-24">

        <!-- Eyebrow -->
        <div class="flex items-center gap-4 text-center sm:text-left">
          <span class="block h-px w-10 bg-stone-400/60 sm:block hidden"></span>
          <span class="text-[0.65rem] font-semibold uppercase tracking-[0.45em] text-stone-500 mx-auto sm:mx-0">
            Gallery
          </span>
        </div>

        <!-- Large editorial heading -->
        <h1
          class="mt-6 font-['Plus_Jakarta_Sans'] text-[clamp(3.2rem,10vw,9rem)] font-semibold leading-[0.88] tracking-[-0.07em] text-stone-900"
        >
          Every event,<br class="sm:hidden" /><span class="sm:inline"> </span>captured.
        </h1>

        <!-- Divider + description + CTA -->
        <div
          class="mt-10 grid gap-6 border-t border-stone-900/10 pt-8 text-center sm:text-left lg:grid-cols-[1fr_auto] lg:items-center"
        >
          <p class="mx-auto max-w-lg text-base leading-8 text-stone-600 lg:mx-0">
            Photos and video highlights from corporate functions, community
            celebrations, and everything in between.
          </p>
          <a
            href="/#contact"
            class="btn-primary mx-auto sm:mx-0"
            style="color: #ffffff;"
            >Book an event</a
          >
        </div>

        <!-- Contact-sheet strip -->
        <div
          class="relative mt-14 overflow-hidden"
          aria-hidden="true"
          style="-webkit-mask-image: linear-gradient(to right, transparent 0%, white 12%, white 88%, transparent 100%); mask-image: linear-gradient(to right, transparent 0%, white 12%, white 88%, transparent 100%);"
        >
          <svg
            viewBox="0 0 1200 100"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full"
            preserveAspectRatio="xMidYMid meet"
          >
            <g fill="none" stroke="rgba(28,25,23,0.14)" stroke-linecap="round">
              <!-- 8 thumbnail frames -->
              {
                [0, 1, 2, 3, 4, 5, 6, 7].map((i) => {
                  const x = 20 + i * 147;
                  const y = 12;
                  const w = 130;
                  const h = 76;
                  const b = 8; // bracket size
                  return (
                    <g>
                      <rect x={x} y={y} width={w} height={h} stroke-width="1" />
                      {/* top-left bracket */}
                      <path d={`M${x},${y + b} V${y} H${x + b}`} stroke-width="1.5" />
                      {/* top-right bracket */}
                      <path d={`M${x + w - b},${y} H${x + w} V${y + b}`} stroke-width="1.5" />
                      {/* bottom-left bracket */}
                      <path d={`M${x},${y + h - b} V${y + h} H${x + b}`} stroke-width="1.5" />
                      {/* bottom-right bracket */}
                      <path d={`M${x + w - b},${y + h} H${x + w} V${y + h - b}`} stroke-width="1.5" />
                      {/* faint horizon rule inside */}
                      <line x1={x + 12} y1={y + h / 2} x2={x + w - 12} y2={y + h / 2} stroke-width="0.6" stroke-opacity="0.5" />
                      {/* tiny centre dot */}
                      <circle cx={x + w / 2} cy={y + h / 2} r="2" fill="rgba(28,25,23,0.09)" stroke="none" />
                    </g>
                  );
                })
              }
              <!-- Frame number ticks below strip -->
              {
                [0, 1, 2, 3, 4, 5, 6, 7].map((i) => {
                  const cx = 85 + i * 147;
                  return (
                    <g>
                      <line x1={cx} y1={92} x2={cx} y2={97} stroke-width="0.8" stroke-opacity="0.4" />
                    </g>
                  );
                })
              }
            </g>
          </svg>
          <!-- Strip fades to bg at bottom via gradient -->
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 h-10"
            style="background: linear-gradient(to bottom, transparent, #fbfaf7);"
          ></div>
        </div>
      </div>
    </section>

    <!-- Photo gallery -->
    <section class="border-b border-stone-900/10 bg-[#fbfaf7] py-20 sm:py-24">
      <div class="mx-auto max-w-7xl space-y-10 px-5 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Photo gallery"
          title="Live moments, crowd interaction, and after-event snapshots."
          mobileCenter={true}
        />

        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {
            siteData.photos.map((photo) => (
              <article class="space-y-5 text-center md:text-left">
                <div class="relative">
                  <div
                    class="pointer-events-none absolute inset-0 translate-x-[6px] translate-y-[6px] border border-stone-900/12"
                    aria-hidden="true"
                  ></div>
                  <div class="group relative overflow-hidden border border-stone-900/12">
                    <span
                      class="pointer-events-none absolute left-3 top-3 z-10 block h-5 w-5 border-l border-t border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    <span
                      class="pointer-events-none absolute bottom-3 right-3 z-10 block h-5 w-5 border-b border-r border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    <img
                      src={photo.image}
                      alt={photo.title}
                      class="h-72 w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03]"
                    />
                  </div>
                </div>
                <div class="space-y-2 px-1">
                  <div class="flex items-center justify-center gap-3 md:justify-start">
                    <span class="block h-px w-6 bg-stone-400/50"></span>
                    <p class="text-xs font-semibold uppercase tracking-[0.32em] text-stone-600">
                      {photo.location}
                    </p>
                  </div>
                  <h2 class="font-['Plus_Jakarta_Sans'] text-lg font-semibold tracking-[-0.03em] text-stone-900">
                    {photo.title}
                  </h2>
                  <p class="text-sm leading-7 text-stone-700">
                    {photo.description}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Video showcase -->
    <section class="bg-[#f0ebe3] py-20 sm:py-24">
      <div class="mx-auto max-w-7xl space-y-10 px-5 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Video showcase"
          title="Short highlights from hosted events."
          mobileCenter={true}
        />

        <div class="grid gap-8 lg:grid-cols-3">
          {
            siteData.videos.map((video) => (
              <article class="space-y-5 text-center lg:text-left">
                <div class="relative">
                  <div
                    class="pointer-events-none absolute inset-0 translate-x-[6px] translate-y-[6px] border border-stone-900/12"
                    aria-hidden="true"
                  ></div>
                  <div class="group relative overflow-hidden border border-stone-900/12">
                    <span
                      class="pointer-events-none absolute left-3 top-3 z-10 block h-5 w-5 border-l border-t border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    <span
                      class="pointer-events-none absolute bottom-3 right-3 z-10 block h-5 w-5 border-b border-r border-white/80 [filter:drop-shadow(0_0_1px_rgba(28,25,23,0.35))]"
                      aria-hidden="true"
                    ></span>
                    <img
                      src={video.poster}
                      alt={video.title}
                      class="h-64 w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03]"
                    />
                    <!-- Date + duration bar -->
                    <div class="absolute inset-x-0 top-0 flex items-center justify-between px-5 py-3 text-[0.58rem] font-semibold uppercase tracking-[0.32em] text-white/80">
                      <span>{video.date}</span>
                      <span>{video.duration}</span>
                    </div>
                    <!-- Play button -->
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="flex h-14 w-14 items-center justify-center rounded-full border border-white/50 bg-stone-950/48 backdrop-blur-sm transition duration-300 group-hover:bg-stone-950/65">
                        <svg
                          viewBox="0 0 24 24"
                          class="h-5 w-5 translate-x-0.5 fill-white"
                          aria-hidden="true"
                        >
                          <path d="M8 5v14l11-7z" />
                        </svg>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="space-y-2 px-1">
                  <div class="flex items-center justify-center gap-3 lg:justify-start">
                    <span class="block h-px w-6 bg-stone-400/50"></span>
                    <p class="text-[0.6rem] font-semibold uppercase tracking-[0.35em] text-stone-500">
                      {video.date}
                    </p>
                  </div>
                  <h2 class="font-['Plus_Jakarta_Sans'] text-lg font-semibold tracking-[-0.03em] text-stone-900">
                    {video.title}
                  </h2>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
