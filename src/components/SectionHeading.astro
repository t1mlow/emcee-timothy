---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: "left" | "center";
  mobileCenter?: boolean;
}

const { eyebrow, title, text, align = "left", mobileCenter = false } =
  Astro.props;
const centered = align === "center";
---

<div
  class:list={[
    "space-y-4",
    centered && "mx-auto max-w-2xl text-center",
    mobileCenter && !centered && "text-center sm:text-left",
  ]}
>
  {
    eyebrow && (
      <div
        class:list={[
          "flex items-center gap-4",
          centered && "justify-center",
          mobileCenter && !centered && "justify-center sm:justify-start",
        ]}
      >
        <span class="h-px w-12 bg-stone-900/18" />
        <p class="text-xs font-semibold uppercase tracking-[0.32em] text-stone-600">
          {eyebrow}
        </p>
        {mobileCenter && !centered && (
          <span class="h-px w-12 bg-stone-900/18 sm:hidden" />
        )}
      </div>
    )
  }
  <h2
    class="font-['Plus_Jakarta_Sans'] text-3xl font-semibold tracking-[-0.04em] text-stone-900 sm:text-4xl"
  >
    {title}
  </h2>
  {text && <p class="max-w-2xl text-base leading-8 text-stone-700">{text}</p>}
</div>
