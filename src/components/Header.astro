---
interface Props {
  pathname?: string;
}

const { pathname = "/" } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/gallery", label: "Gallery" },
];

const contact = {
  instagramUrl: "https://www.instagram.com/mceetimothy/",
  whatsappUrl: "https://wa.me/6596917191",
  email: "mceetimothy@gmail.com",
};
---

<header class="site-header sticky top-0 z-50 bg-[#e6ddd2]">
  <div
    class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-2.5 sm:px-6 lg:px-8"
  >
    <a
      href="/"
      class="font-['Plus_Jakarta_Sans'] text-lg font-bold uppercase tracking-[0.3em] text-stone-900"
    >
      Emcee Timothy
    </a>

    <div class="flex items-center gap-8">
      <nav class="hidden items-center gap-8 text-sm text-stone-600 sm:flex">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={[
                "nav-link py-1 font-medium text-stone-600 transition hover:text-stone-900",
                pathname === link.href &&
                  "font-semibold text-stone-900 underline decoration-current underline-offset-[0.45rem]",
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <a
        href="/#contact"
        class="btn-primary hidden px-2.5 py-1 text-sm sm:inline-flex"
        style="color: #ffffff;"
      >
        Enquire
      </a>

      <button
        type="button"
        class="mobile-menu-toggle grid h-10 w-10 cursor-pointer place-items-center rounded-full border border-stone-900/10 bg-[#f3ece3]/88 text-stone-900 sm:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="sr-only">Open menu</span>
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="mobile-menu pointer-events-none fixed inset-0 z-[60] bg-stone-950/40 opacity-0 backdrop-blur-[2px] transition duration-300 sm:hidden"
  aria-hidden="true"
>
  <div
    class="mobile-menu-panel absolute right-0 top-0 flex h-full w-[min(86vw,22rem)] translate-x-full flex-col overflow-y-auto border-l border-stone-900/10 bg-[#e6ddd2] p-6 shadow-[-28px_0_60px_rgba(23,19,18,0.14)] transition duration-300"
    style="background-color: #e6ddd2;"
  >
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      <div
        class="absolute right-[-3.5rem] top-16 h-40 w-40 rounded-full border border-stone-900/8 bg-white/40"
      >
      </div>
      <div
        class="absolute top-[50%] left-[-2.5rem] h-28 w-28 rounded-full border border-stone-900/8 bg-white/30"
      >
      </div>
      <div
        class="absolute top-[57%] left-6 font-['Plus_Jakarta_Sans'] text-[4.5rem] font-semibold uppercase tracking-[-0.08em] text-stone-900/4"
      >
        Emcee
      </div>
    </div>
    <div class="flex items-center justify-between">
      <div class="space-y-1">
        <a
          href="/"
          class="font-['Plus_Jakarta_Sans'] text-sm font-semibold uppercase tracking-[0.3em] text-stone-900"
        >
          Emcee Timothy
        </a>
        <p class="text-sm text-stone-600">Calm hosting. Clean delivery.</p>
      </div>
      <button
        type="button"
        class="mobile-menu-close grid h-8 w-8 cursor-pointer place-items-center text-stone-900"
        aria-label="Close menu"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>

    <nav class="relative mt-12 flex flex-col gap-5 text-base text-stone-700">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "mobile-nav-item flex items-center gap-3 py-1 transition hover:text-stone-900",
              pathname === link.href &&
                "font-semibold text-stone-900 underline decoration-current underline-offset-[0.45rem]",
            ]}
          >
            {link.href === "/" ? (
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M3 10.5 12 3l9 7.5" />
                <path d="M5 9.5V21h14V9.5" />
              </svg>
            ) : (
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <rect x="4" y="5" width="16" height="14" rx="2" />
                <path d="M8 9h8M8 13h5" />
              </svg>
            )}
            {link.label}
          </a>
        ))
      }
      <a
        href="/#contact"
        class="mobile-nav-item flex items-center gap-3 py-1 text-base font-semibold text-stone-900 transition hover:text-stone-900"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M12 5v14M5 12h14"></path>
        </svg>
        Enquire
      </a>
    </nav>

    <div class="relative mt-auto space-y-4 border-t border-stone-900/10 pt-6">
      <div class="flex items-center gap-3">
        <a
          class="grid h-11 w-11 place-items-center rounded-full border border-stone-900/10 bg-white/80 text-stone-900 transition hover:-translate-y-px hover:shadow-md"
          href={contact.instagramUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 fill-none stroke-current stroke-2"
          >
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1"></circle>
          </svg>
        </a>
        <a
          class="grid h-11 w-11 place-items-center rounded-full border border-stone-900/10 bg-white/80 text-stone-900 transition hover:-translate-y-px hover:shadow-md"
          href={contact.whatsappUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="WhatsApp"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 fill-current"
          >
            <path
              d="M19.05 4.94A9.77 9.77 0 0 0 12.08 2a9.9 9.9 0 0 0-8.58 14.84L2 22l5.3-1.38a9.82 9.82 0 0 0 4.72 1.2h.01A9.98 9.98 0 0 0 22 11.92a9.76 9.76 0 0 0-2.95-6.98Zm-6.97 15.2a8.13 8.13 0 0 1-4.14-1.13l-.3-.18-3.15.82.84-3.07-.2-.31a8.17 8.17 0 0 1 6.95-12.52 8.08 8.08 0 0 1 5.77 2.42 8.14 8.14 0 0 1-5.77 13.97Zm4.47-6.1c-.24-.12-1.4-.7-1.62-.77-.22-.08-.38-.12-.54.12-.16.23-.62.76-.76.91-.14.16-.28.18-.52.06-.24-.12-1-.37-1.9-1.16-.7-.62-1.18-1.39-1.31-1.62-.14-.23-.01-.36.1-.48.1-.1.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.42-.54-.43h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.12 3.64.57.24 1.02.38 1.36.49.57.18 1.09.16 1.5.1.46-.07 1.4-.57 1.6-1.12.2-.56.2-1.03.14-1.13-.06-.1-.22-.16-.46-.28Z"
            ></path>
          </svg>
        </a>
        <button
          type="button"
          data-copy-email={contact.email}
          class="grid h-11 w-11 cursor-pointer place-items-center rounded-full border border-stone-900/10 bg-white/80 text-stone-900 transition hover:-translate-y-px hover:shadow-md"
          aria-label="Email"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 fill-none stroke-current stroke-2"
          >
            <path d="M4 6h16v12H4z"></path>
            <path d="m4 7 8 6 8-6"></path>
          </svg>
        </button>
      </div>
      <p class="max-w-xs text-sm leading-7 text-stone-600">
        For community, corporate, and private events. Reach out for dates,
        programme flow, or package details.
      </p>
    </div>
  </div>
</div>

<div
  class="copy-email-toast pointer-events-none fixed left-1/2 top-1/2 z-[80] -translate-x-1/2 -translate-y-1/2 rounded-full bg-stone-950 px-5 py-3 text-sm font-medium text-white opacity-0 shadow-[0_18px_40px_rgba(23,19,18,0.24)] transition duration-300"
  aria-live="polite"
>
  Email copied
</div>

<script>
  const header = document.querySelector(".site-header");
  const menu = document.querySelector("#mobile-menu");
  const panel = menu?.querySelector(".mobile-menu-panel");
  const toggle = document.querySelector(".mobile-menu-toggle");
  const closeButton = menu?.querySelector(".mobile-menu-close");
  const copyEmailToast = document.querySelector(".copy-email-toast");

  const syncHeader = () => {
    if (!header) return;
    if (window.scrollY > 12) {
      header.classList.add("is-scrolled");
    } else {
      header.classList.remove("is-scrolled");
    }
  };

  const openMenu = () => {
    if (!menu || !panel || !toggle) return;
    menu.classList.remove("pointer-events-none", "opacity-0");
    menu.setAttribute("aria-hidden", "false");
    panel.classList.remove("translate-x-full");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  const closeMenu = () => {
    if (!menu || !panel || !toggle) return;
    menu.classList.add("pointer-events-none", "opacity-0");
    menu.setAttribute("aria-hidden", "true");
    panel.classList.add("translate-x-full");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  toggle?.addEventListener("click", openMenu);
  closeButton?.addEventListener("click", closeMenu);
  menu?.addEventListener("click", (event) => {
    if (event.target === menu) closeMenu();
  });
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  const copyEmailButton = menu?.querySelector("[data-copy-email]");
  let copyEmailTimer: ReturnType<typeof window.setTimeout> | undefined;

  copyEmailButton?.addEventListener("click", async () => {
    const email = copyEmailButton.getAttribute("data-copy-email");
    if (!email || !copyEmailToast) return;

    try {
      await navigator.clipboard.writeText(email);
      copyEmailToast.textContent = "Email copied";
    } catch {
      copyEmailToast.textContent = email;
    }

    copyEmailToast.classList.remove("opacity-0");
    clearTimeout(copyEmailTimer);
    copyEmailTimer = window.setTimeout(() => {
      copyEmailToast.classList.add("opacity-0");
    }, 1800);
  });

  window.addEventListener("scroll", syncHeader, { passive: true });
  syncHeader();
</script>
