---
import { siteData } from "../data/site";
---

<footer class="px-4 pb-6 sm:px-6 lg:px-8">
  <div
    class="relative mx-auto grid max-w-7xl gap-10 overflow-hidden border-t border-stone-900/12 bg-[#121212] px-5 py-16 text-stone-100 sm:px-6 lg:grid-cols-[1.2fr_0.8fr] lg:px-8"
  >
    <div class="space-y-4">
      <p class="text-xs uppercase tracking-[0.35em] text-stone-400">
        Connect with Timothy
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          class="icon-button border-white/20 bg-transparent text-stone-100 hover:border-white/35 hover:bg-white/5 hover:text-white"
          href={siteData.contact.instagramUrl}
          aria-label="Instagram"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 fill-none stroke-current stroke-2"
          >
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1"></circle>
          </svg>
        </a>
        <a
          class="icon-button border-white/20 bg-transparent text-stone-100 hover:border-[var(--accent)] hover:bg-[var(--accent)] hover:text-white"
          href={siteData.contact.whatsappUrl}
          aria-label="WhatsApp"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 fill-current"
          >
            <path
              d="M19.05 4.94A9.77 9.77 0 0 0 12.08 2a9.9 9.9 0 0 0-8.58 14.84L2 22l5.3-1.38a9.82 9.82 0 0 0 4.72 1.2h.01A9.98 9.98 0 0 0 22 11.92a9.76 9.76 0 0 0-2.95-6.98Zm-6.97 15.2a8.13 8.13 0 0 1-4.14-1.13l-.3-.18-3.15.82.84-3.07-.2-.31a8.17 8.17 0 0 1 6.95-12.52 8.08 8.08 0 0 1 5.77 2.42 8.14 8.14 0 0 1-5.77 13.97Zm4.47-6.1c-.24-.12-1.4-.7-1.62-.77-.22-.08-.38-.12-.54.12-.16.23-.62.76-.76.91-.14.16-.28.18-.52.06-.24-.12-1-.37-1.9-1.16-.7-.62-1.18-1.39-1.31-1.62-.14-.23-.01-.36.1-.48.1-.1.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.42-.54-.43h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.12 3.64.57.24 1.02.38 1.36.49.57.18 1.09.16 1.5.1.46-.07 1.4-.57 1.6-1.12.2-.56.2-1.03.14-1.13-.06-.1-.22-.16-.46-.28Z"
            ></path>
          </svg>
        </a>
        <button
          type="button"
          class="copy-email-btn icon-button border-white/20 bg-transparent text-stone-100 hover:border-white/35 hover:bg-white/5 hover:text-white"
          data-email={siteData.contact.email}
          aria-label="Copy email"
        >
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 fill-none stroke-current stroke-2"
          >
            <path d="M4 6h16v12H4z"></path>
            <path d="m4 7 8 6 8-6"></path>
          </svg>
        </button>
      </div>
      <p class="text-sm text-stone-300">WhatsApp: +65 9691 7191</p>
    </div>

    <div class="space-y-4">
      <p class="text-xs uppercase tracking-[0.35em] text-stone-400">
        Booking enquiries
      </p>
      <p class="max-w-md text-sm leading-7 text-stone-200">
        Drop in your preferred event date, audience type, and rough programme
        flow. WhatsApp and Instagram are already linked for quick enquiries.
      </p>
      <p class="text-sm text-stone-300">{siteData.contact.email}</p>
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 translate-y-1/3 px-5 pb-6 font-['Plus_Jakarta_Sans'] text-[clamp(3.5rem,11vw,9rem)] font-semibold uppercase leading-none tracking-[-0.06em] text-white/6 sm:px-6 lg:px-8"
    >
      Mic Up Your Event
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll(".copy-email-btn").forEach((button) => {
    button.addEventListener("click", async () => {
      const email = button.getAttribute("data-email");
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
        button.setAttribute("aria-label", "Email copied");
      } catch {
        window.location.href = `mailto:${email}`;
      }
    });
  });
</script>
