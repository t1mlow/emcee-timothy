---
import { siteData } from "../data/site";
---

<footer>
  <div
    class="relative overflow-hidden border-t border-stone-900/12 bg-[#121212] text-stone-100"
  >
    <!-- Background: scattered sparkles -->
    <svg
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 h-full w-full"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1000 400"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <radialGradient id="footer-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="white" stop-opacity="0.06"></stop>
          <stop offset="100%" stop-color="white" stop-opacity="0"></stop>
        </radialGradient>
      </defs>

      <!-- subtle glow bloom top-right -->
      <ellipse cx="870" cy="60" rx="200" ry="140" fill="url(#footer-glow)"
      ></ellipse>

      <!-- large sparkle — top right -->
      <g transform="translate(870, 90)" opacity="0.6">
        <path d="M0,-18 L2,0 L0,18 L-2,0 Z" fill="white"></path>
        <path d="M-18,0 L0,2 L18,0 L0,-2 Z" fill="white"></path>
      </g>

      <!-- medium sparkle — upper centre-left -->
      <g transform="translate(310, 80)" opacity="0.4">
        <path d="M0,-11 L1.2,0 L0,11 L-1.2,0 Z" fill="white"></path>
        <path d="M-11,0 L0,1.2 L11,0 L0,-1.2 Z" fill="white"></path>
      </g>

      <!-- small sparkle — left side mid -->
      <g transform="translate(60, 220)" opacity="0.35">
        <path d="M0,-7 L0.8,0 L0,7 L-0.8,0 Z" fill="white"></path>
        <path d="M-7,0 L0,0.8 L7,0 L0,-0.8 Z" fill="white"></path>
      </g>

      <!-- small sparkle — bottom centre-right -->
      <g transform="translate(680, 340)" opacity="0.3">
        <path d="M0,-8 L0.9,0 L0,8 L-0.9,0 Z" fill="white"></path>
        <path d="M-8,0 L0,0.9 L8,0 L0,-0.9 Z" fill="white"></path>
      </g>

      <!-- tiny sparkle — top left corner -->
      <g transform="translate(120, 50)" opacity="0.25">
        <path d="M0,-5 L0.6,0 L0,5 L-0.6,0 Z" fill="white"></path>
        <path d="M-5,0 L0,0.6 L5,0 L0,-0.6 Z" fill="white"></path>
      </g>

      <!-- dot cluster — right side -->
      <circle cx="950" cy="200" r="2" fill="white" opacity="0.3"></circle>
      <circle cx="940" cy="215" r="1.2" fill="white" opacity="0.2"></circle>
      <circle cx="958" cy="222" r="1.5" fill="white" opacity="0.18"></circle>

      <!-- dot cluster — bottom left -->
      <circle cx="40" cy="340" r="1.8" fill="white" opacity="0.25"></circle>
      <circle cx="52" cy="352" r="1.2" fill="white" opacity="0.18"></circle>

      <!-- lone dot — centre top -->
      <circle cx="500" cy="30" r="1.5" fill="white" opacity="0.22"></circle>
    </svg>

    <!-- Star/compass — desktop-only background decoration -->
    <svg
      aria-hidden="true"
      class="pointer-events-none absolute hidden lg:block"
      style="right: 12%; top: 52%; transform: translateY(-50%);"
      width="200"
      height="200"
      viewBox="0 0 200 200"
      xmlns="http://www.w3.org/2000/svg"
      opacity="0.07"
    >
      <!-- Concentric rings -->
      <circle
        cx="100"
        cy="100"
        r="95"
        fill="none"
        stroke="white"
        stroke-width="1"></circle>
      <circle
        cx="100"
        cy="100"
        r="74"
        fill="none"
        stroke="white"
        stroke-width="0.6"></circle>
      <circle
        cx="100"
        cy="100"
        r="52"
        fill="none"
        stroke="white"
        stroke-width="0.5"></circle>
      <!-- Cross lines -->
      <line x1="100" y1="5" x2="100" y2="195" stroke="white" stroke-width="0.5"
      ></line>
      <line x1="5" y1="100" x2="195" y2="100" stroke="white" stroke-width="0.5"
      ></line>
      <line x1="33" y1="33" x2="167" y2="167" stroke="white" stroke-width="0.4"
      ></line>
      <line x1="167" y1="33" x2="33" y2="167" stroke="white" stroke-width="0.4"
      ></line>
      <!-- Centre sparkle -->
      <path d="M100,78 L102.5,100 L100,122 L97.5,100 Z" fill="white"></path>
      <path d="M78,100 L100,102.5 L122,100 L100,97.5 Z" fill="white"></path>
      <path
        d="M100,85 L101.8,100 L100,115 L98.2,100 Z"
        fill="white"
        transform="rotate(45 100 100)"></path>
      <path
        d="M85,100 L100,101.8 L115,100 L100,98.2 Z"
        fill="white"
        transform="rotate(45 100 100)"></path>
      <!-- Tick dots at cardinal points -->
      <circle cx="100" cy="5" r="2.5" fill="white"></circle>
      <circle cx="100" cy="195" r="2.5" fill="white"></circle>
      <circle cx="5" cy="100" r="2.5" fill="white"></circle>
      <circle cx="195" cy="100" r="2.5" fill="white"></circle>
    </svg>

    <div class="relative z-[1] mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <!-- Row 1: Watermark -->
      <div
        class="select-none overflow-hidden pt-8 text-center"
        style="-webkit-mask-image: linear-gradient(to bottom, white 50%, transparent 100%); mask-image: linear-gradient(to bottom, white 50%, transparent 100%);"
      >
        <p
          class="whitespace-nowrap font-['Plus_Jakarta_Sans'] text-[clamp(2rem,9vw,10rem)] font-semibold uppercase leading-none tracking-[-0.06em] text-white/[0.08]"
        >
          Mic Up Your Event
        </p>
      </div>

      <!-- Row 2: Left + Right content -->
      <div
        class="grid gap-10 pb-16 pt-10 sm:pl-8 lg:pl-20 xl:pl-0 lg:grid-cols-[1fr_1fr]"
      >
        <div class="space-y-4 text-center lg:text-left">
          <p class="text-xs uppercase tracking-[0.35em] text-stone-400">
            Closing note
          </p>
          <h2
            class="mx-auto max-w-md text-2xl font-semibold tracking-[-0.04em] text-white lg:mx-0"
          >
            Calm on stage, clear in delivery, memorable in the room.
          </h2>
          <p class="mx-auto max-w-lg text-sm leading-7 text-stone-300 lg:mx-0">
            A steady voice for celebrations, launches, and community moments
            that need warmth without noise.
          </p>
        </div>

        <div class="space-y-4 text-center lg:text-left">
          <p class="text-xs uppercase tracking-[0.35em] text-stone-400">
            Connect with Timothy
          </p>
          <div class="flex flex-wrap justify-center gap-3 lg:justify-start">
            <a
              class="icon-button footer-social-button border-white/20 bg-transparent text-stone-100"
              href={siteData.contact.instagramUrl}
              aria-label="Instagram"
              target="_blank"
              rel="noreferrer"
            >
              <svg
                viewBox="0 0 24 24"
                aria-hidden="true"
                class="h-5 w-5 fill-none stroke-current stroke-2"
              >
                <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle cx="17.5" cy="6.5" r="1"></circle>
              </svg>
            </a>
            <a
              class="icon-button footer-social-button border-white/20 bg-transparent text-stone-100"
              href={siteData.contact.whatsappUrl}
              aria-label="WhatsApp"
              target="_blank"
              rel="noreferrer"
            >
              <svg
                viewBox="0 0 24 24"
                aria-hidden="true"
                class="h-5 w-5 fill-current"
              >
                <path
                  d="M19.05 4.94A9.77 9.77 0 0 0 12.08 2a9.9 9.9 0 0 0-8.58 14.84L2 22l5.3-1.38a9.82 9.82 0 0 0 4.72 1.2h.01A9.98 9.98 0 0 0 22 11.92a9.76 9.76 0 0 0-2.95-6.98Zm-6.97 15.2a8.13 8.13 0 0 1-4.14-1.13l-.3-.18-3.15.82.84-3.07-.2-.31a8.17 8.17 0 0 1 6.95-12.52 8.08 8.08 0 0 1 5.77 2.42 8.14 8.14 0 0 1-5.77 13.97Zm4.47-6.1c-.24-.12-1.4-.7-1.62-.77-.22-.08-.38-.12-.54.12-.16.23-.62.76-.76.91-.14.16-.28.18-.52.06-.24-.12-1-.37-1.9-1.16-.7-.62-1.18-1.39-1.31-1.62-.14-.23-.01-.36.1-.48.1-.1.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.42-.54-.43h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.12 3.64.57.24 1.02.38 1.36.49.57.18 1.09.16 1.5.1.46-.07 1.4-.57 1.6-1.12.2-.56.2-1.03.14-1.13-.06-.1-.22-.16-.46-.28Z"
                ></path>
              </svg>
            </a>
            <button
              type="button"
              class="copy-email-btn icon-button footer-social-button border-white/20 bg-transparent text-stone-100"
              data-email={siteData.contact.email}
              aria-label="Copy email"
            >
              <svg
                viewBox="0 0 24 24"
                aria-hidden="true"
                class="h-5 w-5 fill-none stroke-current stroke-2"
              >
                <path d="M4 6h16v12H4z"></path>
                <path d="m4 7 8 6 8-6"></path>
              </svg>
            </button>
          </div>
          <p class="mx-auto max-w-xs text-sm leading-6 text-stone-400 lg:mx-0">
            Every event starts with a conversation.
          </p>
        </div>

        <div
          class="border-t border-white/10 pt-6 text-center text-xs uppercase tracking-[0.24em] text-stone-400 lg:col-span-2"
        >
          <p>
            &copy; {new Date().getFullYear()} Emcee Timothy. All rights reserved.
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>

<div
  class="copy-email-toast pointer-events-none fixed left-1/2 top-1/2 z-[80] -translate-x-1/2 -translate-y-1/2 rounded-full border border-stone-900/12 bg-[#171312] px-4 py-2 text-sm font-medium text-white opacity-0 shadow-[0_18px_40px_rgba(23,19,18,0.18)] transition duration-200"
  aria-live="polite"
>
  Email copied
</div>

<script>
  const footerEmailToast = document.querySelector(".copy-email-toast");
  let footerCopyEmailTimer: ReturnType<typeof setTimeout> | undefined =
    undefined;

  document.querySelectorAll(".copy-email-btn").forEach((button) => {
    button.addEventListener("click", async () => {
      const email = button.getAttribute("data-email");
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
      } catch {
        window.location.href = `mailto:${email}`;
        return;
      }

      if (!footerEmailToast) return;

      footerEmailToast.textContent = "Email copied";
      footerEmailToast.classList.remove("opacity-0");
      footerEmailToast.classList.add("opacity-100");

      if (footerCopyEmailTimer) {
        window.clearTimeout(footerCopyEmailTimer);
      }

      footerCopyEmailTimer = window.setTimeout(() => {
        footerEmailToast.classList.remove("opacity-100");
        footerEmailToast.classList.add("opacity-0");
      }, 1800);
    });
  });
</script>
