---
import { siteData } from "../../data/site";
---

<section id="contact" class="bg-[#fbfaf7] py-20 sm:py-24">
  <div
    class="mx-auto grid max-w-7xl gap-12 px-5 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:px-8"
  >
    <!-- Left: heading -->
    <div class="space-y-6 text-center lg:text-left">
      <div class="flex items-center justify-center gap-4 lg:justify-start">
        <span class="block h-px w-10 bg-stone-400/60"></span>
        <span
          class="text-[0.65rem] font-semibold uppercase tracking-[0.45em] text-stone-500"
          >Get in touch</span
        >
        <span class="block h-px w-10 bg-stone-400/60 lg:hidden"></span>
      </div>
      <h2
        class="font-['Plus_Jakarta_Sans'] text-4xl font-semibold tracking-[-0.05em] text-stone-900 sm:text-5xl"
      >
        Planning a dinner, celebration, launch, or community programme?
      </h2>
      <p class="mx-auto max-w-lg text-base leading-8 text-stone-600 lg:mx-0 lg:border-l-2 lg:border-stone-900/12 lg:pl-5">
        Start with a short message about the date, audience, and event tone.
      </p>
    </div>

    <!-- Right: focused CTA -->
    <div class="space-y-5 lg:pl-8">
      <a
        href={siteData.contact.whatsappUrl}
        class="btn-primary flex w-full items-center justify-center gap-3 py-4 text-sm"
        style="color: #ffffff;"
        target="_blank"
        rel="noreferrer"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
          <path
            d="M19.05 4.94A9.77 9.77 0 0 0 12.08 2a9.9 9.9 0 0 0-8.58 14.84L2 22l5.3-1.38a9.82 9.82 0 0 0 4.72 1.2h.01A9.98 9.98 0 0 0 22 11.92a9.76 9.76 0 0 0-2.95-6.98Zm-6.97 15.2a8.13 8.13 0 0 1-4.14-1.13l-.3-.18-3.15.82.84-3.07-.2-.31a8.17 8.17 0 0 1 6.95-12.52 8.08 8.08 0 0 1 5.77 2.42 8.14 8.14 0 0 1-5.77 13.97Zm4.47-6.1c-.24-.12-1.4-.7-1.62-.77-.22-.08-.38-.12-.54.12-.16.23-.62.76-.76.91-.14.16-.28.18-.52.06-.24-.12-1-.37-1.9-1.16-.7-.62-1.18-1.39-1.31-1.62-.14-.23-.01-.36.1-.48.1-.1.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.48-.4-.42-.54-.43h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.12 3.64.57.24 1.02.38 1.36.49.57.18 1.09.16 1.5.1.46-.07 1.4-.57 1.6-1.12.2-.56.2-1.03.14-1.13-.06-.1-.22-.16-.46-.28Z"
          ></path>
        </svg>
        Message on WhatsApp
      </a>

      <div class="flex items-center gap-4">
        <span class="h-px flex-1 bg-stone-900/8"></span>
        <span class="text-[0.6rem] uppercase tracking-[0.35em] text-stone-400">or</span>
        <span class="h-px flex-1 bg-stone-900/8"></span>
      </div>

      <button
        type="button"
        class="copy-email-btn btn-secondary w-full justify-center"
        data-email={siteData.contact.email}
        aria-label="Copy email address"
      >
        {siteData.contact.email}
      </button>
    </div>
  </div>
</section>
