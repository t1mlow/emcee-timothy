---
import { siteData } from "../../data/site";
---

<section
  class="relative flex min-h-[88vh] items-center overflow-hidden border-b border-stone-900/10 bg-[#fbfaf7]"
>
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="background-image: radial-gradient(circle, rgba(120,113,108,0.13) 1px, transparent 1px); background-size: 26px 26px;"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 70% 80% at 35% 50%, rgba(251,250,247,0) 30%, rgba(251,250,247,0.97) 75%);"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="background: radial-gradient(ellipse at bottom right, rgba(230,223,214,0.5) 0%, transparent 55%);"
  >
  </div>

  <div
    class="pointer-events-none absolute inset-0 overflow-hidden lg:hidden"
    aria-hidden="true"
  >
    <div
      class="absolute -right-20 -top-10 h-64 w-64 rounded-full border border-stone-900/7 bg-white/35"
    >
    </div>
    <div
      class="absolute -right-8 top-24 h-40 w-40 rounded-full border border-stone-900/6 bg-white/25"
    >
    </div>
    <div
      class="absolute -left-14 bottom-20 h-52 w-52 rounded-full border border-stone-900/6 bg-white/28"
    >
    </div>
    <div
      class="absolute bottom-10 left-20 font-['Plus_Jakarta_Sans'] text-[7rem] font-semibold uppercase leading-none tracking-[-0.08em] text-stone-900/[0.035]"
    >
      MC
    </div>
  </div>

  <div
    class="relative z-10 mx-auto w-full max-w-7xl px-5 py-20 sm:px-6 lg:px-8"
  >
    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="space-y-8 text-center lg:text-left">
        <div class="flex items-center justify-center gap-4 lg:justify-start">
          <span class="block h-px w-10 bg-stone-400/60"></span>
          <span
            class="text-[0.65rem] font-semibold uppercase tracking-[0.45em] text-stone-500"
          >
            Professional Emcee
          </span>
          <span class="block h-px w-10 bg-stone-400/60 lg:hidden"></span>
        </div>

        <h1
          class="font-['Plus_Jakarta_Sans'] text-[clamp(3.2rem,8vw,6.6rem)] font-semibold leading-[0.92] tracking-[-0.075em] text-stone-900"
        >
          Calm presence.<br />Clean delivery.
        </h1>

        <p
          class="mx-auto max-w-md text-base leading-8 text-stone-600 lg:mx-0 lg:border-l-2 lg:border-stone-900/12 lg:pl-5"
        >
          {siteData.tagline}
        </p>

        <div class="flex flex-wrap justify-center gap-3 lg:justify-start">
          <a href="#contact" class="btn-primary" style="color: #ffffff;">
            Book an event
          </a>
          <a href="/gallery" class="btn-secondary">View gallery</a>
        </div>

        <div class="flex items-center gap-0 border-t border-stone-900/8 pt-5">
          <span class="text-[0.6rem] uppercase tracking-[0.4em] text-stone-400">
            Calm
          </span>
          <span class="mx-4 h-px flex-1 bg-stone-900/8"></span>
          <span class="text-[0.6rem] uppercase tracking-[0.4em] text-stone-400">
            Composed
          </span>
          <span class="mx-4 h-px flex-1 bg-stone-900/8"></span>
          <span class="text-[0.6rem] uppercase tracking-[0.4em] text-stone-400">
            Memorable
          </span>
        </div>
      </div>

      <div
        class="hidden lg:flex lg:items-center lg:justify-center"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 420 420"
          class="h-[30rem] w-[30rem]"
          xmlns="http://www.w3.org/2000/svg"
        >
          <circle
            cx="210"
            cy="210"
            r="198"
            fill="none"
            stroke="rgba(28,25,23,0.1)"
            stroke-width="0.8"></circle>
          <line
            x1="210"
            y1="12"
            x2="210"
            y2="32"
            stroke="rgba(28,25,23,0.25)"
            stroke-width="1.5"
            stroke-linecap="round"></line>
          <line
            x1="210"
            y1="388"
            x2="210"
            y2="408"
            stroke="rgba(28,25,23,0.25)"
            stroke-width="1.5"
            stroke-linecap="round"></line>
          <line
            x1="12"
            y1="210"
            x2="32"
            y2="210"
            stroke="rgba(28,25,23,0.25)"
            stroke-width="1.5"
            stroke-linecap="round"></line>
          <line
            x1="388"
            y1="210"
            x2="408"
            y2="210"
            stroke="rgba(28,25,23,0.25)"
            stroke-width="1.5"
            stroke-linecap="round"></line>
          <circle
            cx="210"
            cy="210"
            r="158"
            fill="none"
            stroke="rgba(28,25,23,0.08)"
            stroke-width="0.9"
            stroke-dasharray="827 166"
            transform="rotate(-90, 210, 210)"></circle>
          <line
            x1="12"
            y1="210"
            x2="408"
            y2="210"
            stroke="rgba(28,25,23,0.04)"
            stroke-width="0.6"></line>
          <line
            x1="210"
            y1="12"
            x2="210"
            y2="408"
            stroke="rgba(28,25,23,0.04)"
            stroke-width="0.6"></line>
          <circle
            cx="210"
            cy="210"
            r="115"
            fill="none"
            stroke="rgba(28,25,23,0.1)"
            stroke-width="0.7"
            stroke-dasharray="440 282"
            transform="rotate(50, 210, 210)"></circle>
          <circle
            cx="210"
            cy="210"
            r="70"
            fill="rgba(255,255,255,0.22)"
            stroke="rgba(28,25,23,0.06)"
            stroke-width="0.6"></circle>
          <rect
            x="188"
            y="82"
            width="44"
            height="118"
            rx="22"
            fill="rgba(255,255,255,0.5)"
            stroke="rgba(28,25,23,0.18)"
            stroke-width="1.8"></rect>
          <ellipse
            cx="210"
            cy="128"
            rx="9"
            ry="11"
            fill="none"
            stroke="rgba(28,25,23,0.11)"
            stroke-width="1.2"></ellipse>
          <line
            x1="210"
            y1="200"
            x2="210"
            y2="272"
            stroke="rgba(28,25,23,0.15)"
            stroke-width="1.8"
            stroke-linecap="round"></line>
          <path
            d="M168,272 Q210,298 252,272"
            fill="none"
            stroke="rgba(28,25,23,0.15)"
            stroke-width="1.8"
            stroke-linecap="round"></path>
          <path
            d="M234,108 Q268,108 268,141 Q268,174 234,174"
            fill="none"
            stroke="rgba(28,25,23,0.1)"
            stroke-width="1.4"
            stroke-linecap="round"></path>
          <g transform="translate(210,10)">
            <path d="M0,-8 L1.1,0 L0,8 L-1.1,0 Z" fill="rgba(28,25,23,0.4)"
            ></path>
            <path d="M-8,0 L0,1.1 L8,0 L0,-1.1 Z" fill="rgba(28,25,23,0.4)"
            ></path>
          </g>
          <circle cx="210" cy="410" r="2.2" fill="rgba(28,25,23,0.2)"></circle>
          <circle cx="10" cy="210" r="2.2" fill="rgba(28,25,23,0.2)"></circle>
          <circle cx="410" cy="210" r="2.2" fill="rgba(28,25,23,0.2)"></circle>
        </svg>
      </div>
    </div>
  </div>
</section>
