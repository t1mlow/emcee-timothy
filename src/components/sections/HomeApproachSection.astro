---
import SectionHeading from "../SectionHeading.astro";
import { siteData } from "../../data/site";
---

<section
  class="relative overflow-hidden border-b border-stone-900/10 bg-[#f0ebe3] py-20 sm:py-24"
>
  <div class="mx-auto max-w-7xl space-y-10 px-5 sm:px-6 lg:px-8">
    <div
      class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_14rem] lg:items-start xl:grid-cols-[minmax(0,1fr)_18rem]"
    >
      <SectionHeading
        eyebrow="The approach"
        title="Present in every room. Tuned to every crowd."
        text="A minimalist stage presence does not mean flat delivery. The hosting approach shifts with the crowd while keeping the tone intentional and composed."
        mobileCenter={true}
      />

      <div class="hidden lg:flex lg:justify-end lg:pt-3" aria-hidden="true">
        <svg
          class="h-auto w-full max-w-[14rem] xl:max-w-[18rem]"
          viewBox="0 0 290 160"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g stroke="rgba(28,25,23,0.13)" stroke-linecap="round" fill="none">
            <line x1="10" y1="68" x2="10" y2="92" stroke-width="1.5"></line>
            <line x1="28" y1="55" x2="28" y2="105" stroke-width="1.5"></line>
            <line x1="46" y1="62" x2="46" y2="98" stroke-width="1.5"></line>
            <line x1="64" y1="42" x2="64" y2="118" stroke-width="1.5"></line>
            <line x1="82" y1="50" x2="82" y2="110" stroke-width="1.5"></line>
            <line x1="100" y1="30" x2="100" y2="130" stroke-width="1.5"></line>
            <line x1="118" y1="38" x2="118" y2="122" stroke-width="1.5"></line>
            <line x1="136" y1="20" x2="136" y2="140" stroke-width="1.5"></line>
            <line x1="154" y1="35" x2="154" y2="125" stroke-width="1.5"></line>
            <line x1="172" y1="45" x2="172" y2="115" stroke-width="1.5"></line>
            <line x1="190" y1="58" x2="190" y2="102" stroke-width="1.5"></line>
            <line x1="208" y1="48" x2="208" y2="112" stroke-width="1.5"></line>
            <line x1="226" y1="63" x2="226" y2="97" stroke-width="1.5"></line>
            <line x1="244" y1="55" x2="244" y2="105" stroke-width="1.5"></line>
            <line x1="262" y1="70" x2="262" y2="90" stroke-width="1.5"></line>
            <line x1="280" y1="75" x2="280" y2="85" stroke-width="1.5"></line>
          </g>
        </svg>
      </div>
    </div>

    <div
      class="grid gap-0 divide-y divide-stone-900/8 text-center lg:grid-cols-3 lg:divide-x lg:divide-y-0 lg:text-left"
    >
      {
        siteData.services.map((service, index) => (
          <article class="space-y-4 py-8 lg:px-8 lg:py-0 first:lg:pl-0 last:lg:pr-0">
            <span class="block text-[0.6rem] font-semibold uppercase tracking-[0.45em] text-stone-400">
              0{index + 1}
            </span>
            <h3 class="font-['Plus_Jakarta_Sans'] text-xl font-semibold tracking-[-0.04em] text-stone-900">
              {service.title}
            </h3>
            <p class="text-sm leading-7 text-stone-600">
              {service.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
